# Application
APP_PORT=3000
APP_NAME=KotlinAdmin
SESSION_SECRET=change_me_32_char_secret_key_here
APP_MODE=full

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kotlinadmin
DB_USERNAME=postgres
DB_PASSWORD=secret

# JWT
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=1h

# Session
SESSION_TTL_HOURS=6
# Session storage driver: database | redis (default: database)
# - database : simpan sesi di tabel `sessions` DB utama. Persist lintas restart.
# - redis    : simpan sesi di Redis. Sesi hilang saat Redis restart.
SESSION_DRIVER=database

# Redis
REDIS_URL=redis://localhost:6379

# Bcrypt
BCRYPT_ROUNDS=10

# OTP
OTP_EXPIRY_MINUTES=10

# Pagination
DEFAULT_PAGE_SIZE=10

# Storage — pindah driver cukup lewat .env (tanpa ubah kode/view).
# STORAGE_DRIVER: local | oss | s3
#   local : file di STORAGE_BASE_PATH, disajikan pada /storage/<key>
#   oss   : Alibaba OSS  (butuh ACCESS_KEY/SECRET/ENDPOINT/BUCKET)
#   s3    : AWS S3 / S3-compatible (MinIO, R2, B2) — presigned URL
STORAGE_DRIVER=local
# Direktori penyimpanan lokal (driver=local). Boleh absolut (mis. /data/uploads).
STORAGE_BASE_PATH=uploads
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_SSL=true

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=KotlinAdmin
MAIL_FROM_ADDRESS=noreply@example.com
